class SentenceOrgan:
    def __init__(self):
        self.last_sentence = ""
        self.next_sentence = ""

    def update_sentences(self, final_sentence: str, preview_sentence: str):
        # shift preview into last, store new preview
        if final_sentence:
            self.last_sentence = final_sentence
        if preview_sentence:
            self.next_sentence = preview_sentence

    def get_last_sentence(self) -> str:
        return self.last_sentence

    def get_next_sentence(self) -> str:
        return self.next_sentence


