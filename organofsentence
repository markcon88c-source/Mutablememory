# sentence_viewer.py
# =========================

def render_sentence_viewer(sentence_organ: SentenceOrgan, crawl_lines: list[str]) -> str:
    last_sentence = sentence_organ.get_last_sentence()
    next_sentence = sentence_organ.get_next_sentence()

    lines = []
    lines.append("=== SENTENCE VIEWER ===")
    lines.append("")
    lines.append("FINAL SENTENCE:")
    lines.append(last_sentence if last_sentence else "(none yet)")
    lines.append("")
    lines.append("PREVIEW:")
    lines.append(next_sentence if next_sentence else "(none yet)")
    lines.append("")
    lines.append("CRAWL:")
    for line in crawl_lines:
        lines.append(f"  {line}")

    return "\n".join(lines)
