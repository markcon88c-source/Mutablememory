#!/usr/bin/env python3

"""
DIALOGUE FORCE ORGAN
--------------------
This organ computes the interaction pressure between two Speech Blocks.
It does NOT generate English, and it does NOT generate Speech Blocks.

It only answers one question:
    "How strongly does Block A pull Block B into a specific kind of response?"

This is the physics of dialogue.
"""

class DialogueForceOrgan:
    def __init__(self):
        pass

    # ------------------------------------------------------------
    # PUBLIC API
    # ------------------------------------------------------------
    def compute(self, block_A, block_B):
        """
        Compute the dialogue force between two speech blocks.
        block_A = the line that was just spoken
        block_B = the new block being generated
        """

        if block_A is None or block_B is None:
            return 0.0

        # 1. Question Pull
        question_pull = self._question_pull(block_A)

        # 2. Answer Resonance
        answer_resonance = self._answer_resonance(block_A, block_B)

        # 3. Tension Alignment
        tension_alignment = self._alignment(
            block_A.social_core.get("tension", 0.0),
            block_B.social_core.get("tension", 0.0)
        )

        # 4. Curiosity Alignment
        curiosity_alignment = self._alignment(
            block_A.social_core.get("curiosity", 0.0),
            block_B.social_core.get("curiosity", 0.0)
        )

        # 5. Emotional Mirroring
        emotional_mirroring = self._alignment(
            block_A.emotional_core.get("valence", 0.0),
            block_B.emotional_core.get("valence", 0.0)
        )

        # 6. Semantic Completion
        semantic_completion = self._semantic_completion(block_A, block_B)

        # 7. Dominance Response
        dominance_response = self._dominance_response(block_A, block_B)

        # 8. Memory Echo Alignment
        memory_echo_alignment = self._alignment(
            block_A.semantic_core.get("memory_echo", 0.0),
            block_B.semantic_core.get("memory_echo", 0.0)
        )

        # Final Dialogue Force
        dialogue_force = (
            question_pull +
            answer_resonance +
            tension_alignment +
            curiosity_alignment +
            emotional_mirroring +
            semantic_completion +
            dominance_response +
            memory_echo_alignment
        ) / 8.0

        return dialogue_force

    # ------------------------------------------------------------
    # INTERNAL HELPERS
    # ------------------------------------------------------------

    def _question_pull(self, block):
        """If block A ends with a question, it exerts a pull."""
        intent = block.english.get("intent", "")
        return 1.0 if intent == "question" else 0.0

    def _answer_resonance(self, A, B):
        """Do the word forces in B resonate with the semantic pressure of A?"""
        A_map = A.semantic_core.get("word_force_map", {})
        B_map = B.semantic_core.get("word_force_map", {})

        overlap = 0.0
        for word, force_A in A_map.items():
            if word in B_map:
                force_B = B_map[word]
                overlap += min(force_A, force_B)

        return overlap

    def _alignment(self, a, b):
        """Simple force alignment: 1.0 when identical, 0.0 when opposite."""
        return 1.0 - abs(a - b)

    def _semantic_completion(self, A, B):
        """Does B complete the conceptual seeds of A?"""
        A_concepts = set(A.semantic_core.get("concept_seed", []))
        B_concepts = set(B.semantic_core.get("concept_seed", []))

        if not A_concepts:
            return 0.0

        return len(A_concepts.intersection(B_concepts)) / len(A_concepts)

    def _dominance_response(self, A, B):
        """How much does B respond to A's dominance vector?"""
        dom_A = A.social_core.get("dominance", 0.0)
        dom_B = B.social_core.get("dominance", 0.0)
        return abs(dom_A - dom_B)
